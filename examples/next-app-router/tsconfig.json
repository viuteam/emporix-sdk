{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["ES2022", "DOM"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "verbatimModuleSyntax": false
  },
  "include": ["next-env.d.ts", "app", ".next/types/**/*.ts"]
}
