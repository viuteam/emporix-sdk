{
  "name": "@viu/emporix-sdk-monorepo",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20.19.0" },
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "lint": "pnpm -r --filter \"./packages/*\" lint",
    "typecheck": "pnpm -r typecheck",
    "e2e": "pnpm --filter @viu/emporix-e2e exec playwright test",
    "e2e:headed": "pnpm --filter @viu/emporix-e2e exec playwright test --headed",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm -r --filter \"./packages/*\" build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@changesets/changelog-github": "^0.5.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.1.0",
    "typescript": "^5.6.0"
  }
}
