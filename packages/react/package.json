{
  "name": "@viu/emporix-sdk-react",
  "version": "2.19.1",
  "description": "React bindings for the Emporix SDK",
  "license": "MIT",
  "author": {
    "name": "viu",
    "url": "https://github.com/viuteam"
  },
  "homepage": "https://github.com/viuteam/emporix-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viuteam/emporix-sdk.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/viuteam/emporix-sdk/issues"
  },
  "keywords": [
    "emporix",
    "ecommerce",
    "commerce",
    "react",
    "react-query",
    "hooks",
    "typescript",
    "storefront"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js",
      "require": "./dist/provider.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js",
      "require": "./dist/hooks.cjs"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.js",
      "require": "./dist/storage.cjs"
    },
    "./ssr": {
      "types": "./dist/ssr.d.ts",
      "import": "./dist/ssr.js",
      "require": "./dist/ssr.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "check:dist": "node scripts/check-dist.mjs",
    "test": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.51.0",
    "@viu/emporix-sdk": "workspace:^",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.51.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.16",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@viu/emporix-sdk": "workspace:*",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.0",
    "msw": "^2.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.2.0",
    "typescript": "^5.6.0",
    "undici": "^6.19.0",
    "vitest": "^2.0.0"
  }
}
